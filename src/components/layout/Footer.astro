---
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-ghost mt-auto bg-surface-deep/50">
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
      <!-- Left: Brand + Copyright -->
      <div class="space-y-3">
        <div class="flex items-baseline gap-2">
          <span class="font-display font-700 text-ink">Will Mangaroo</span>
          <span class="text-[13px] text-ink-faint font-mono tracking-wide uppercase">PM</span>
        </div>
        <p class="text-sm text-ink-faint">
          &copy; {year} Will Mangaroo. Built for clarity and speed.
        </p>
      </div>

      <!-- Right: Links -->
      <nav class="flex items-center gap-6" aria-label="Footer navigation">
        <a href="/hot-topics" class="text-sm text-ink-muted hover:text-accent transition-colors duration-200">
          Hot Topics
        </a>
        <a href="/about" class="text-sm text-ink-muted hover:text-accent transition-colors duration-200">
          About
        </a>
        <a href="/contact" class="text-sm text-ink-muted hover:text-accent transition-colors duration-200">
          Contact
        </a>
        <a
          href="https://www.linkedin.com/in/william-mangaroo"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-ink-muted hover:text-accent transition-colors duration-200"
        >
          LinkedIn
        </a>
      </nav>
    </div>
  </div>
</footer>
