---
import { Image } from 'astro:assets';
import heroImage from '@assets/images/hero.jpg';
---

<section class="relative overflow-hidden">
  <!-- Accent glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] bg-accent/[0.07] rounded-full blur-[150px] pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-36">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Hero Content -->
      <div class="space-y-8 animate-fade-up">
        <!-- Announcement pill -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/[0.06] text-[13px] font-medium text-accent-light relative overflow-hidden">
          <span class="absolute inset-0 rounded-full animate-shimmer bg-[length:200%_100%] bg-gradient-to-r from-transparent via-accent/10 to-transparent pointer-events-none"></span>
          <span class="relative flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-teal animate-glow-pulse"></span>
            Open to Product Manager Roles
          </span>
        </div>

        <!-- Monospace label -->
        <div class="flex items-center gap-3">
          <div class="accent-line"></div>
          <span class="font-mono text-[13px] text-accent tracking-wider uppercase">Portfolio</span>
        </div>

        <!-- Title -->
        <h1 class="font-display font-800 text-[clamp(2.5rem,4.8vw,3.75rem)] leading-[1.1] tracking-[-0.03em] text-ink">
          Explore product thinking <span class="text-accent">in action.</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-ink-muted leading-relaxed max-w-[48ch]">
          A small, high-signal library of how I work: discovery, prioritization, trade-offs, and delivery. Backed by real artifacts and source links.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 pt-2">
          <a href="/hot-topics" class="btn-primary">
            Explore Hot Topics
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/about" class="btn-ghost">
            How I Work
          </a>
        </div>

        <!-- Stats Row -->
        <div class="grid grid-cols-3 gap-4 pt-6 border-t border-ink-ghost animate-fade-up stagger-3">
          <div class="space-y-1">
            <dt class="text-[12px] font-mono text-ink-faint tracking-wider uppercase">Strength</dt>
            <dd class="text-[15px] font-semibold text-ink">Discovery → Delivery</dd>
          </div>
          <div class="space-y-1">
            <dt class="text-[12px] font-mono text-ink-faint tracking-wider uppercase">Focus</dt>
            <dd class="text-[15px] font-semibold text-ink">Clarity + Outcomes</dd>
          </div>
          <div class="space-y-1">
            <dt class="text-[12px] font-mono text-ink-faint tracking-wider uppercase">Outputs</dt>
            <dd class="text-[15px] font-semibold text-ink">Stories, Specs, Demos</dd>
          </div>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="animate-fade-up stagger-2">
        <div class="relative group">
          <!-- Glow behind image -->
          <div class="absolute -inset-4 bg-gradient-to-tr from-accent/20 via-teal/10 to-accent/5 rounded-[20px] blur-2xl opacity-50 group-hover:opacity-70 transition-opacity duration-700" aria-hidden="true"></div>

          <!-- Image container -->
          <div class="relative rounded-2xl overflow-hidden border border-ink-ghost shadow-card-hover">
            <Image
              src={heroImage}
              alt="William Mangaroo - Product Manager"
              class="w-full h-auto block"
              widths={[400, 600, 800]}
              sizes="(max-width: 768px) 100vw, 45vw"
              loading="eager"
              fetchpriority="high"
            />
            <!-- Gradient overlay at bottom -->
            <div class="absolute inset-x-0 bottom-0 h-1/4 bg-gradient-to-t from-surface-deep/60 to-transparent pointer-events-none" aria-hidden="true"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
