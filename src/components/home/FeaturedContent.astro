---
import { getCollection } from 'astro:content';

const allHotTopics = await getCollection('hot-topics');
const featuredItems = allHotTopics
  .filter((item) => item.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const getBadgeClass = (type: string) => {
  const classes = {
    article: 'badge-article',
    audio: 'badge-audio',
    video: 'badge-video',
  };
  return classes[type as keyof typeof classes] || 'badge-article';
};

const getTypeLabel = (type: string) => {
  return { article: 'Article', audio: 'Audio', video: 'Video' }[type] || 'Article';
};
---

<section class="section relative">
  <div class="content-wrapper">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <div class="accent-line"></div>
          <span class="font-mono text-[13px] text-accent tracking-wider uppercase">Featured</span>
        </div>
        <h2 class="font-display font-700 text-3xl md:text-4xl text-ink tracking-tight">
          Hot Topics
        </h2>
        <p class="text-ink-muted text-lg max-w-[50ch]">
          PM insights, frameworks, and real-world scenarios
        </p>
      </div>
      <a href="/hot-topics" class="btn-ghost shrink-0">
        View All
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Featured Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featuredItems.map((item, i) => (
        <article
          class={`card card-glow p-7 flex flex-col hover:-translate-y-1 transition-all duration-300 animate-fade-up stagger-${i + 1}`}
        >
          <!-- Type Badge -->
          <span class:list={['badge', getBadgeClass(item.data.type)]}>
            {getTypeLabel(item.data.type)}
          </span>

          <!-- Title -->
          <h3 class="mt-5 font-display font-700 text-xl text-ink tracking-tight leading-snug">
            <a href={`/hot-topics/${item.id}`} class="hover:text-accent transition-colors duration-200">
              {item.data.title}
            </a>
          </h3>

          <!-- Summary -->
          <p class="mt-3 text-ink-muted text-[15px] leading-relaxed line-clamp-3 flex-1">
            {item.data.summary}
          </p>

          <!-- Tags -->
          <div class="mt-5 flex flex-wrap gap-2">
            {item.data.tags.slice(0, 3).map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>

          <!-- CTA -->
          <div class="mt-5 pt-5 border-t border-ink-ghost">
            <a
              href={`/hot-topics/${item.id}`}
              class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-accent-light transition-colors group"
            >
              {item.data.type === 'article' && 'Read article'}
              {item.data.type === 'audio' && `Listen${item.data.duration ? ` · ${item.data.duration}` : ''}`}
              {item.data.type === 'video' && `Watch${item.data.duration ? ` · ${item.data.duration}` : ''}`}
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
