---
const values = [
  {
    label: '01',
    title: 'Product Thinking',
    description: 'Clear tradeoffs, crisp narratives, and artifacts that show how decisions were made.',
    accent: 'from-accent/20 to-accent/5',
    iconColor: 'text-accent',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  },
  {
    label: '02',
    title: 'Execution',
    description: 'From discovery to delivery, with practical workflows that teams can actually follow.',
    accent: 'from-teal/20 to-teal/5',
    iconColor: 'text-teal',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    label: '03',
    title: 'Results',
    description: 'Items are tagged with outcomes and metrics so impact is obvious at a glance.',
    accent: 'from-coral/20 to-coral/5',
    iconColor: 'text-coral',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
];
---

<section class="section relative">
  <!-- Subtle divider glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-px bg-gradient-to-r from-transparent via-ink-ghost to-transparent" aria-hidden="true"></div>

  <div class="content-wrapper">
    <!-- Section Header -->
    <div class="max-w-2xl mb-16 space-y-4">
      <div class="flex items-center gap-3">
        <div class="accent-line"></div>
        <span class="font-mono text-[13px] text-accent tracking-wider uppercase">Capabilities</span>
      </div>
      <h2 class="font-display font-700 text-3xl md:text-4xl text-ink tracking-tight">
        What you'll see here
      </h2>
      <p class="text-ink-muted text-lg leading-relaxed">
        A quick tour of the skills behind the work. How I frame problems, align stakeholders,
        make decisions under constraints, and follow through to measurable outcomes.
      </p>
    </div>

    <!-- Value Cards -->
    <div class="grid md:grid-cols-3 gap-6">
      {values.map((item, i) => (
        <div class={`card p-8 group hover:-translate-y-1 transition-all duration-300 animate-fade-up stagger-${i + 1}`}>
          <!-- Number + Icon -->
          <div class="flex items-center justify-between mb-6">
            <span class="font-mono text-[13px] text-ink-faint tracking-wider">{item.label}</span>
            <div class={`w-12 h-12 rounded-[10px] bg-gradient-to-br ${item.accent} flex items-center justify-center`}>
              <svg class={`w-6 h-6 ${item.iconColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
              </svg>
            </div>
          </div>

          <h3 class="font-display font-700 text-xl text-ink tracking-tight mb-3">
            {item.title}
          </h3>

          <p class="text-ink-muted text-[15px] leading-relaxed">
            {item.description}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA Card -->
    <div class="mt-16">
      <div class="card card-glow relative overflow-hidden p-10 md:p-14">
        <!-- Background gradient -->
        <div class="absolute inset-0 bg-gradient-to-br from-accent/[0.06] via-transparent to-teal/[0.04] pointer-events-none" aria-hidden="true"></div>

        <div class="relative max-w-3xl mx-auto text-center space-y-6">
          <h3 class="font-display font-700 text-2xl md:text-3xl text-ink tracking-tight">
            Want the fastest proof of fit?
          </h3>
          <p class="text-ink-muted text-lg">
            Start with featured work and filter by type or tag.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4 pt-2">
            <a href="/hot-topics" class="btn-primary">
              Go to Hot Topics
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/contact" class="btn-ghost">
              Contact
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
