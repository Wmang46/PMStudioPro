---
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Theme Toggle Script (inline to prevent FOUC) -->
    <script is:inline src="/theme-toggle.js"></script>

    <!-- Fonts: Syne (display) + DM Sans (body) + JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Syne:wght@600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-surface-deep text-ink font-sans antialiased">
    <!-- Skip to main content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-btn"
    >
      Skip to main content
    </a>

    <!-- Floating geometric shapes -->
    <div class="fixed inset-0 -z-10 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="floating-shape w-[18px] h-[18px] top-[12%] left-[8%] animate-float opacity-40" style="animation-delay: 0s;"></div>
      <div class="floating-shape w-[14px] h-[14px] top-[28%] right-[12%] animate-float-slow opacity-30" style="animation-delay: -2s;"></div>
      <div class="floating-shape w-[22px] h-[22px] top-[55%] left-[15%] animate-float-slower opacity-25" style="animation-delay: -4s;"></div>
      <div class="floating-shape w-[10px] h-[10px] top-[70%] right-[20%] animate-float opacity-35" style="animation-delay: -1s;"></div>
      <div class="floating-shape w-[16px] h-[16px] top-[40%] left-[75%] animate-float-slow opacity-20" style="animation-delay: -3s;"></div>
      <div class="floating-shape w-[12px] h-[12px] top-[85%] left-[40%] animate-float-slower opacity-30" style="animation-delay: -5s;"></div>
      <div class="floating-shape w-[20px] h-[20px] top-[15%] left-[55%] animate-float opacity-20" style="animation-delay: -2.5s;"></div>
    </div>

    <Header />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
