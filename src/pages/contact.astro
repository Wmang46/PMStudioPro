---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Will Mangaroo"
  description="Get in touch to discuss product management opportunities, consulting, or collaborations."
>
  <div class="content-wrapper py-16 md:py-24">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="mb-12 space-y-4 animate-fade-up">
        <div class="flex items-center gap-3">
          <div class="accent-line"></div>
          <span class="font-mono text-[13px] text-accent tracking-wider uppercase">Connect</span>
        </div>
        <h1 class="font-display font-800 text-4xl md:text-5xl text-ink tracking-tight">
          Get in Touch
        </h1>
        <p class="text-xl text-ink-muted">
          Interested in working together? Let's connect.
        </p>
      </div>

      <!-- Contact Card -->
      <div class="card card-glow p-8 md:p-10 animate-fade-up stagger-1">
        <h2 class="font-display font-700 text-2xl text-ink tracking-tight mb-8">
          Contact Information
        </h2>

        <div class="space-y-8">
          <!-- LinkedIn -->
          <div class="group">
            <h3 class="text-[12px] font-mono text-ink-faint tracking-wider uppercase mb-3">LinkedIn</h3>
            <a
              href="https://www.linkedin.com/in/william-mangaroo"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 text-accent hover:text-accent-light transition-colors"
            >
              <div class="w-10 h-10 rounded-[10px] bg-accent/10 flex items-center justify-center group-hover:bg-accent/15 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <span class="font-medium">Connect on LinkedIn</span>
            </a>
          </div>

          <!-- Email -->
          <div>
            <h3 class="text-[12px] font-mono text-ink-faint tracking-wider uppercase mb-3">Preferred Contact</h3>
            <p class="text-ink-muted">
              LinkedIn message is the best way to reach me.
            </p>
          </div>
        </div>

        <!-- Divider + Quick Links -->
        <div class="mt-10 pt-8 border-t border-ink-ghost">
          <p class="text-sm text-ink-faint">
            Looking for quick proof of fit? Check out my
            <a href="/hot-topics" class="text-accent hover:text-accent-light transition-colors font-medium">Hot Topics</a>
            or view
            <a href="/about" class="text-accent hover:text-accent-light transition-colors font-medium">my projects</a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
