---
import BaseLayout from '@layouts/BaseLayout.astro';
import { projects } from '@/data/projects';
import { skillCategories } from '@/data/skills';
---

<BaseLayout
  title="About Will Mangaroo | Product Manager"
  description="Product Manager with 15+ years driving product strategy, discovery, and delivery across retail banking, digital platforms, fraud prevention, and core systems modernization."
>
  <div class="content-wrapper py-16 md:py-24">
    <!-- Introduction -->
    <section class="max-w-3xl mb-20 animate-fade-up">
      <div class="flex items-center gap-3 mb-6">
        <div class="accent-line"></div>
        <span class="font-mono text-[13px] text-accent tracking-wider uppercase">About</span>
      </div>

      <h1 class="font-display font-800 text-4xl md:text-5xl text-ink tracking-tight mb-8">
        About Me
      </h1>

      <div class="space-y-5 text-lg text-ink-muted leading-relaxed">
        <p>
          Product Manager with 15+ years of experience driving product strategy, discovery, and
          delivery across retail banking, digital platforms, contact center operations, fraud
          prevention, and core systems modernization.
        </p>
        <p>
          I turn ambiguous stakeholder needs into clear product roadmaps, measurable OKRs, and
          release-ready outcomes that reduce cost, mitigate risk, and improve customer experience.
          Data-driven by default&mdash;I use KPI tracking and outcome measurement to inform every
          prioritization decision.
        </p>
        <p>
          At Woodforest National Bank, I owned product roadmaps across six banking products&mdash;leading
          initiatives including IVR modernization, core platform migration, fraud-prevention features,
          and a greenfield Customer Information System. These products delivered measurable impact:
          eliminating over 2M monthly agent calls, cutting operating costs by 35%, and migrating
          500K+ accounts with 99.9% data accuracy.
        </p>
        <p>
          Earlier in my career, I led product discovery and delivery for airline and retail
          platforms&mdash;winning competitive bids, shipping ahead of schedule, and driving
          double-digit efficiency gains. Outside of work, I enjoy building systems that simplify
          complex problems and help teams deliver with clarity and confidence.
        </p>
      </div>
    </section>

    <!-- Career Highlights -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="accent-line"></div>
        <span class="font-mono text-[13px] text-accent tracking-wider uppercase">Impact</span>
      </div>
      <h2 class="font-display font-700 text-3xl text-ink tracking-tight mb-10">
        Career Highlights
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="card p-7 animate-fade-up stagger-1">
          <h3 class="font-display font-700 text-lg text-ink tracking-tight mb-3">
            Platform Migration at Scale
          </h3>
          <p class="text-ink-muted text-[15px] leading-relaxed">
            Owned the product roadmap for an end-to-end FIS core migration, shipping 500K+ accounts
            with 99.9% data accuracy and making the build-vs-buy call to retire legacy systems.
          </p>
        </div>

        <div class="card p-7 animate-fade-up stagger-2">
          <h3 class="font-display font-700 text-lg text-ink tracking-tight mb-3">
            Product Velocity & Quality
          </h3>
          <p class="text-ink-muted text-[15px] leading-relaxed">
            Raised team velocity 25%, cut defect escape rate 50%, and shortened time-to-market 30%
            across a six-product portfolio through backlog discipline and delivery optimization.
          </p>
        </div>

        <div class="card p-7 animate-fade-up stagger-3">
          <h3 class="font-display font-700 text-lg text-ink tracking-tight mb-3">
            IVR Product Vision
          </h3>
          <p class="text-ink-muted text-[15px] leading-relaxed">
            Defined the product vision for an IVR modernization that eliminated 2M+ monthly agent
            calls and cut operating costs by 35%&mdash;turning a platform crisis into a strategic win.
          </p>
        </div>

        <div class="card p-7 animate-fade-up stagger-4">
          <h3 class="font-display font-700 text-lg text-ink tracking-tight mb-3">
            Fraud Prevention Roadmap
          </h3>
          <p class="text-ink-muted text-[15px] leading-relaxed">
            Prioritized fraud-prevention features that cut risk exposure by 60% and reduced
            fraud/error rates by 75%&mdash;driven by KPI tracking and outcome-based prioritization.
          </p>
        </div>

        <div class="card p-7 md:col-span-2 animate-fade-up stagger-5">
          <h3 class="font-display font-700 text-lg text-ink tracking-tight mb-3">
            Zero-to-One Product Launch
          </h3>
          <p class="text-ink-muted text-[15px] leading-relaxed">
            Owned vision, design, and launch of a greenfield Customer Information System&mdash;a
            new product that improved transaction processing by 33% and eliminated costly core
            licensing dependency for 500+ daily users.
          </p>
        </div>
      </div>
    </section>

    <!-- Work Experience -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="accent-line"></div>
        <span class="font-mono text-[13px] text-accent tracking-wider uppercase">Experience</span>
      </div>
      <h2 class="font-display font-700 text-3xl text-ink tracking-tight mb-10">
        Work Experience
      </h2>

      <div class="space-y-6">
        {projects.map((project, i) => (
          <article class={`card p-8 md:p-10 animate-fade-up stagger-${Math.min(i + 1, 6)}`}>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-5">
              <div>
                <h3 class="font-display font-700 text-2xl text-ink tracking-tight">
                  {project.title}
                </h3>
                <p class="mt-1 text-ink-muted">
                  {project.role} at {project.company}
                </p>
              </div>
              <span class="mt-2 md:mt-0 text-[12px] font-mono text-ink-faint tracking-wider uppercase">
                {project.timeline}
              </span>
            </div>

            <p class="text-ink-muted leading-relaxed mb-6">{project.description}</p>

            <div class="mb-6">
              <h4 class="font-semibold text-ink text-sm uppercase tracking-wider mb-3">Key Outcomes</h4>
              <ul class="space-y-2">
                {project.outcomes.map(outcome => (
                  <li class="flex items-start gap-3 text-ink-muted text-[15px]">
                    <span class="mt-2 w-1.5 h-1.5 rounded-full bg-teal shrink-0" aria-hidden="true"></span>
                    {outcome}
                  </li>
                ))}
              </ul>
            </div>

            <div class="flex flex-wrap gap-2">
              {project.skills.map(skill => (
                <span class="px-3 py-1.5 text-[13px] font-medium bg-accent/10 text-accent-light rounded-md">
                  {skill}
                </span>
              ))}
              {project.technologies?.map(tech => (
                <span class="tag">{tech}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="accent-line"></div>
        <span class="font-mono text-[13px] text-accent tracking-wider uppercase">Toolkit</span>
      </div>
      <h2 class="font-display font-700 text-3xl text-ink tracking-tight mb-10">
        Skills & Expertise
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        {skillCategories.map((category, i) => (
          <div class={`card p-7 animate-fade-up stagger-${Math.min(i + 1, 6)}`}>
            <h3 class="font-display font-700 text-xl text-ink tracking-tight mb-5">
              {category.category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {category.skills.map(skill => (
                <span class="tag">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education & Certifications -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="accent-line"></div>
        <span class="font-mono text-[13px] text-accent tracking-wider uppercase">Credentials</span>
      </div>
      <h2 class="font-display font-700 text-3xl text-ink tracking-tight mb-10">
        Education & Certifications
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="card p-7 animate-fade-up stagger-1">
          <h3 class="font-display font-700 text-xl text-ink tracking-tight mb-2">Education</h3>
          <div class="mt-4">
            <p class="text-ink font-semibold">University of Houston</p>
            <p class="text-ink-muted text-[15px]">Computer and Information Sciences and Support Services</p>
          </div>
        </div>

        <div class="card p-7 animate-fade-up stagger-2">
          <h3 class="font-display font-700 text-xl text-ink tracking-tight mb-2">Certifications</h3>
          <div class="mt-4 space-y-4">
            <div>
              <p class="text-ink font-semibold">SAFe Scrum Master</p>
              <p class="text-ink-faint text-[13px] font-mono">Scaled Agile &middot; Jun 2020</p>
            </div>
            <div>
              <p class="text-ink font-semibold">SAFe Product Owner / Product Manager</p>
              <p class="text-ink-faint text-[13px] font-mono">Scaled Agile &middot; Jun 2020</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section>
      <div class="card card-glow relative overflow-hidden p-10 md:p-14 text-center">
        <div class="absolute inset-0 bg-gradient-to-br from-accent/[0.06] via-transparent to-teal/[0.04] pointer-events-none" aria-hidden="true"></div>
        <div class="relative space-y-5">
          <h2 class="font-display font-700 text-2xl md:text-3xl text-ink tracking-tight">
            Let's Connect
          </h2>
          <p class="text-ink-muted text-lg max-w-xl mx-auto">
            I enjoy connecting with other product and technology professionals.
            Feel free to reach out.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center pt-2">
            <a
              href="/contact"
              class="btn-primary inline-flex"
            >
              Get in Touch
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/in/william-mangaroo"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-ghost inline-flex"
            >
              LinkedIn Profile
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
